# Legisell — Production Environment Template
#
# Usage:
#   cp .env.example .env
#   # Fill in every value marked with <...>
#   nano .env
#
# Key generation helpers (run on the server):
#
#   JWT secrets (run twice — once per secret):
#     openssl rand -hex 32
#
#   Fernet encryption key (SECRETS_ENCRYPTION_KEY):
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#   Strong random passwords (DB, Redis):
#     openssl rand -base64 32 | tr -d '/+=' | head -c 32
#
# NOTE: SECRETS_VAULT_PASSWORD_HASH must NOT be set here.
#       Bcrypt hashes contain $ which Docker Compose interprets as variable substitution.
#       Configure it via the Admin UI after first login (Settings → Secrets Vault).

# ==============================================================================
# Docker Images (GHCR)
# Tag format: ghcr.io/<owner>/<repo>:<version>
# Obtain a PAT with read:packages and run:
#   echo "<token>" | docker login ghcr.io -u <github-username> --password-stdin
# ==============================================================================
IMAGE_BACKEND=ghcr.io/<owner>/legisell-backend:<tag>
IMAGE_FRONTEND=ghcr.io/<owner>/legisell-frontend:<tag>
IMAGE_UPDATER=ghcr.io/<owner>/legisell-updater:<tag>
IMAGE_BACKUP=ghcr.io/<owner>/legisell-backup:<tag>

# ==============================================================================
# Application
# ==============================================================================
APP_NAME=Legisell
APP_ENV=production
DEBUG=false
WORKERS=2

# ==============================================================================
# Domain
# The registered domain name pointing to this server's public IP.
# Used for SSL certificates, CORS, and Nginx server_name.
#
# DNS records required:
#   admin.legisell.de  A  <server-public-ip>   (Admin panel — VPN-only via Tailscale)
#   api.legisell.de    A  <server-public-ip>   (POS License API — port 8443, public)
# ==============================================================================
DOMAIN=legisell.de

# ==============================================================================
# Tailscale
# The private IP assigned to this server by Tailscale.
# Run `tailscale ip -4` on the server to get this value.
# The Nginx frontend container binds ports 443/80 exclusively to this IP, making
# the admin panel invisible from the public internet.
# ==============================================================================
TAILSCALE_LOCAL_IP=<tailscale-ipv4>

# ==============================================================================
# CORS — must exactly match the URL used to access the admin UI (no trailing slash)
# ==============================================================================
CORS_ORIGINS=https://admin.legisell.de

# ==============================================================================
# PostgreSQL
# ==============================================================================
POSTGRES_USER=legisell_prod
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=legisell_prod
POSTGRES_SERVER=legisell-database
POSTGRES_PORT=5432

# Reduced pool sizes for 2 vCPU / 4 GB server
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ==============================================================================
# Redis
# ==============================================================================
REDIS_HOST=legisell-redis
REDIS_PORT=6379
REDIS_PASSWORD=<strong-random-password>
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ==============================================================================
# JWT — generate with: openssl rand -hex 32
# ==============================================================================
JWT_SECRET=<32+-char-random-hex>
JWT_REFRESH_SECRET=<32+-char-random-hex-different-from-above>
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# 2FA / TOTP
# ==============================================================================
TOTP_ISSUER=Legisell

# ==============================================================================
# Secrets Vault
# SECRETS_ENCRYPTION_KEY — Fernet key (see generation command at top of file)
# SECRETS_VAULT_PASSWORD_HASH — do NOT set here; configure via Admin UI after login
# ==============================================================================
SECRETS_ENCRYPTION_KEY=<fernet-base64-key>

# ==============================================================================
# Initial Admin User (seeded automatically on first startup)
# IMPORTANT: Change the password immediately after first login!
# ==============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<temporary-strong-password>
ADMIN_EMAIL=admin@legisell.de

# ==============================================================================
# Logging — json + minimal reduces noise and log size in production
# ==============================================================================
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_VERBOSITY=minimal

# ==============================================================================
# SSL Certificates
# Host path to the directory containing fullchain.pem and privkey.pem.
# This directory is mounted read-only into the Nginx container.
# Default: ./ssl  (relative to docker-compose.yml)
#
# Option A — Self-signed (IP / testing):
#   openssl req -x509 -nodes -newkey rsa:4096 \
#     -keyout ssl/privkey.pem -out ssl/fullchain.pem \
#     -days 365 -subj "/CN=legisell"
#
# Option B — Let's Encrypt (domain):
#   cp /etc/letsencrypt/live/<domain>/fullchain.pem ssl/
#   cp /etc/letsencrypt/live/<domain>/privkey.pem   ssl/
# ==============================================================================
SSL_CERT_DIR=/root/legisell-deployment/ssl

# ==============================================================================
# Updater Service
# Manages system updates via Admin UI at /updater/
# Checks GitHub Releases, patches .env, pulls new images, rolling-recreate
# with rollback support.
# ==============================================================================
DEPLOYMENT_REPO=https://github.com/<owner>/legisell-deployment
COMPOSE_PROJECT_NAME=legisell-prod
COMPOSE_FILES=/app/deployment/docker-compose.yml
DEPLOYMENT_ENV=/app/deployment/.env
MANAGED_SERVICES=backend,worker,frontend,backup
HEALTH_CHECK_URL=http://legisell-backend:8000/health/ready
DOCKER_CONFIG_DIR=~/.docker
# Absolute host-side path to the deployment directory.
# Phase 7 of the upgrade process launches a short-lived temp container from
# the Docker daemon directly (not inside Compose) — bind-mounts must therefore
# use real host paths, not the container-internal /app/deployment/ path.
HOST_COMPOSE_PROJECT_DIR=/root/legisell-deployment

# ==============================================================================
# Backup Service
# Web UI for PostgreSQL backups and restores, reachable at:
#   http://<TAILSCALE_LOCAL_IP>:8400  (VPN-only)
# Credentials for HTTP Basic Auth on the web UI:
# ==============================================================================
BACKUP_USER=<backup-admin-username>
BACKUP_PASSWORD=<strong-random-password>
# BACKUP_DIR must be the absolute path INSIDE the container.
# The docker-compose.yml volume mount is: ./backups:/backups
# Do NOT change this to a relative path — the service will refuse to start.
BACKUP_DIR=/backups
BACKUP_MAX_UPLOAD_MB=500
TZ=UTC
BACKEND_URL=http://legisell-backend:8000

# Optional remote storage — uncomment and fill in to enable:
# SFTP_HOST=
# SFTP_USER=
# SFTP_PASSWORD=
# SFTP_PATH=/backups
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
