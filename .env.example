# Legisell — Production Environment Template
#
# Usage:
#   cp .env.prod.template .env.prod
#   # Fill in all values marked with <...>
#
# Key generation helpers (run on the server):
#
#   JWT secrets (run twice, once per secret):
#     openssl rand -hex 32
#
#   Fernet encryption key (SECRETS_ENCRYPTION_KEY):
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
#   POS ED25519 signing private key (POS_SIGNING_PRIVATE_KEY):
#     python3 -c "import base64; from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; from cryptography.hazmat.primitives.serialization import Encoding, PrivateFormat, NoEncryption; k=Ed25519PrivateKey.generate(); print(base64.b64encode(k.private_bytes(Encoding.Raw, PrivateFormat.Raw, NoEncryption())).decode())"
#
#   Bcrypt hash (SECRETS_VAULT_PASSWORD_HASH — hash a strong vault password of your choice):
#     python3 -c "import bcrypt; print(bcrypt.hashpw(b'<vault-password>', bcrypt.gensalt(12)).decode())"
#
#   Strong random passwords (DB, Redis):
#     openssl rand -base64 32 | tr -d '/+=' | head -c 32

# ==============================================================================
# Application
# ==============================================================================
APP_NAME=Legisell
APP_ENV=production
DEBUG=false
WORKERS=2

# Global timezone — applies to all containers (IANA format)
TZ=Europe/Berlin

# ==============================================================================
# Domain
# The registered domain name pointing to this server's public IP.
# Used for SSL certificates, CORS, and Nginx server_name.
#
# DNS records required:
#   admin.<your-domain>     A  <server-public-ip>   (Admin panel, VPN-only via Tailscale)
#   api.<your-domain>       A  <server-public-ip>   (POS License API, port 8443, public)
#   telegram.<your-domain>  A  <server-public-ip>   (Telegram webhook, port 8443, public path allowlist)
#
# TLS: Let's Encrypt via DNS-01 challenge (certbot-dns-hetzner plugin)
# ==============================================================================
DOMAIN=<your-domain>

# Public Telegram Bot API webhook URL configured in the Admin UI:
# https://telegram.<your-domain>:8443/api/v1/webhooks/telegram

# ==============================================================================
# Tailscale
# The private IP assigned to this server by Tailscale.
# Run `tailscale ip -4` on the server to get this value.
# Run `tailscale ip -4` on the server to get this value.
# The Nginx frontend container binds port 443/80 exclusively to this IP, making
# the admin panel invisible from the public internet.
# ==============================================================================
TAILSCALE_LOCAL_IP=<tailscale-server-ip>

# ==============================================================================
# CORS — must exactly match the URL used to access the admin UI (no trailing slash)
# ==============================================================================
CORS_ORIGINS=https://admin.<your-domain>

# ==============================================================================
# PostgreSQL
# ==============================================================================
POSTGRES_USER=legisell_prod
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=legisell_prod
POSTGRES_SERVER=legisell-database
POSTGRES_PORT=5432

# Reduced pool sizes for 2 vCPU / 4 GB server
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# ==============================================================================
# Redis
# ==============================================================================
REDIS_HOST=legisell-redis
REDIS_PORT=6379
REDIS_PASSWORD=<strong-random-password>
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# ==============================================================================
# JWT — generate with: openssl rand -hex 32
# ==============================================================================
JWT_SECRET=<32+-char-random-hex>
JWT_REFRESH_SECRET=<32+-char-random-hex-different-from-above>
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# 2FA / TOTP
# ==============================================================================
TOTP_ISSUER=Legisell

# ==============================================================================
# Secrets Vault
# SECRETS_ENCRYPTION_KEY  — Fernet key (see generation command above)
# SECRETS_VAULT_PASSWORD_HASH — configured exclusively via the Admin UI after
#   first login (stored in the database). Do NOT set it here.
# ==============================================================================
SECRETS_ENCRYPTION_KEY=<fernet-base64-key>

# ==============================================================================
# POS License Signing
# POS_SIGNING_PRIVATE_KEY is a base64-encoded raw ED25519 private key.
# The matching public key must be embedded in the POS trust store under key_id.
# ==============================================================================
POS_SIGNING_PRIVATE_KEY=<base64-raw-ed25519-private-key>
POS_SIGNING_KEY_ID=legisell-pos-v1
POS_SIGNING_ALGORITHM=ed25519
POS_SIGNING_PAYLOAD_VERSION=1

# ==============================================================================
# Initial Admin User (seeded automatically on first startup)
# IMPORTANT: Change the password immediately after the first login!
# ==============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<temporary-strong-password>
ADMIN_EMAIL=admin@<your-domain>

# ==============================================================================
# Logging — use json + minimal in production to reduce noise and log size
# ==============================================================================
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_VERBOSITY=minimal

# ==============================================================================
# Backup Service (Sidecar Web UI on port 8400, VPN-only)
#
# HTTP Basic Auth credentials for the backup Web UI.
# The service is locked (503) until BACKUP_PASSWORD is set.
# Supports plain-text or bcrypt-hashed passwords.
#   Generate bcrypt hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'<password>', bcrypt.gensalt(12)).decode())"
# Schedule, retention and compression are configured via the Web UI.
# ==============================================================================
BACKUP_USER=backup_admin
BACKUP_PASSWORD=<strong-backup-password>

# ==============================================================================
# Docker Image Tags
# Set by the CI/CD pipeline for each release. The updater patches these values
# in-place when performing an upgrade. All tags must use the same version.
#
# Format: ghcr.io/<owner>/<service>:<version>
# Example: ghcr.io/jahongirhabibov/legisell-backend:1.0.0
# ==============================================================================
IMAGE_BACKEND=ghcr.io/<github-owner>/legisell-backend:<version>
IMAGE_FRONTEND=ghcr.io/<github-owner>/legisell-frontend:<version>
IMAGE_BACKUP=ghcr.io/<github-owner>/legisell-backup:<version>
IMAGE_UPDATER=ghcr.io/<github-owner>/legisell-updater:<version>

# ==============================================================================
# Updater Sidecar
# Public GitHub repo used as the release registry for the update mechanism.
# The updater queries its GitHub Releases API anonymously (no token required).
# Must match DEPLOYMENT_REPO in the GitHub Actions workflow.
# Example: your-org/legisell-deployment
# ==============================================================================
DEPLOYMENT_REPO=<github-owner>/legisell-deployment

# Absolute path to the deployment directory ON THE HOST (not inside the container).
# Required for Phase 7 two-step self-update: the temp-container is started by the
# Docker daemon with host-side bind-mounts, so it needs the real host path.
# Example: /root/legisell-deployment
# If unset, Phase 7 is skipped with a warning — all other services still update.
HOST_COMPOSE_PROJECT_DIR=/root/legisell-deployment

# Docker credentials directory on the host for pulling images from GHCR.
# Default: ~/.docker (standard Docker config location)
# DOCKER_CONFIG_DIR=~/.docker

# ==============================================================================
# SSL Certificates
# Absolute host path to the directory containing fullchain.pem and privkey.pem.
# This directory is mounted read-only into the Nginx container.
#
# MUST be an absolute path — relative paths (e.g. ./ssl) are resolved by Docker
# against --project-directory, which inside the updater container is
# /app/deployment (not the real host directory). A relative path would cause
# nginx to start with an empty mount and crash immediately.
#
# Option A (IP-only, self-signed): generate with openssl — see DEPLOY.md
# Option B (domain, Let's Encrypt): copy from /etc/letsencrypt/live/<domain>/
# ==============================================================================
SSL_CERT_DIR=/root/legisell-deployment/ssl

# ==============================================================================
# Stripe
# Credentials are configured exclusively via the Admin UI (stored in DB).
# Do NOT set these here — env-based Stripe credentials are not supported.
# ==============================================================================
